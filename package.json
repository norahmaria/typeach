{
  "name": "@typeach/components",
  "version": "0.0.6",
  "license": "GNU",
  "author": "Norah Maria",
  "description": "typeach components",
  "sideEffects": false,
  "main": "./dist/index.es.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "component",
    "library",
    "vue"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "yarn story",
    "build": "vite build && yarn build:types",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json",
    "test": "yarn vitest",
    "test:up": "yarn vitest --update",
    "cy:ct": "yarn cypress open --component",
    "cy:ct:run": "yarn cypress run --component",
    "story": "start-storybook -p 6006",
    "story:build": "build-storybook -o docs",
    "lint": "eslint ./src",
    "update": "yarn upgrade --latest",
    "prettier": "prettier --config .prettierrc 'src/**/*.stories.mdx' --write",
    "postinstall": "yarn build",
    "prepublishOnly": "yarn build"
  },
  "engines": {
    "node": "16.15.1"
  },
  "dependencies": {
    "vue": "^3.2.36",
    "vue-style-loader": "^4.1.3"
  },
  "peerDependencies": {
    "vue": "^3.2.36"
  },
  "devDependencies": {
    "@cypress/vite-dev-server": "^2.2.3",
    "@cypress/vue": "^3.1.2",
    "@cypress/webpack-preprocessor": "^5.12.0",
    "@storybook/addon-docs": "^6.5.6",
    "@storybook/addon-essentials": "^6.5.6",
    "@storybook/builder-webpack5": "^6.5.6",
    "@storybook/manager-webpack5": "^6.5.6",
    "@storybook/vue3": "^6.5.6",
    "@typescript-eslint/eslint-plugin": "^5.27.0",
    "@typescript-eslint/parser": "^5.27.0",
    "@vitejs/plugin-vue": "^2.3.3",
    "@vue/eslint-config-airbnb": "^6.0.0",
    "@vue/eslint-config-typescript": "^10.0.0",
    "@vue/test-utils": "^2.0.0",
    "css-loader": "^6.7.1",
    "cypress": "^10.0.2",
    "eslint": "^8.17.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-storybook": "^0.5.12",
    "eslint-plugin-vue": "^9.1.0",
    "eslint-plugin-vuejs-accessibility": "^1.2.0",
    "husky": "^8.0.1",
    "jsdom": "^19.0.0",
    "sass": "^1.52.2",
    "sass-loader": "^13.0.0",
    "typescript": "^4.7.3",
    "vite": "^2.9.9",
    "vitest": "^0.13.1",
    "vue-tsc": "^0.36.1"
  }
}
