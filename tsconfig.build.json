{
  "references": [{ "path": "./tsconfig.node.json" }],
  "exclude": ["**/*.cy.ts", "**/*.spec.ts", "**/*.story.ts"],
  "include": ["src"],
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["esnext", "dom"],
    "skipLibCheck": true,
    "declaration": true,
    "types": ["cypress", "vite/client"],
    "outDir": "dist"
  }
}
