{
  "references": [{ "path": "./tsconfig.node.json" }],
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["esnext", "dom"],
    "skipLibCheck": true,
    "declaration": true,
    "types": ["cypress"],
    "baseUrl": "./packages",
    "paths": {
      "@typeach/button": ["button/src/*"],
      "@typeach/select": ["select/src/*"]
    }
  }
}
